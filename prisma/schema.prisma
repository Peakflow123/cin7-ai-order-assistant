generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  NEW
  NEEDS_REVIEW
  READY
  CREATED
  ERROR
}

enum LineStatus {
  MATCHED
  NEEDS_REVIEW
  UNMATCHED
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  isActive                  Boolean   @default(true)
  isArchived                Boolean   @default(false)
  archivedAt                DateTime?
  deletedAt                 DateTime?
  allowClientCin7Edit       Boolean   @default(false)
  autoCreateEnabled         Boolean   @default(true)
  autoCreateThreshold       Float     @default(0.9)
  allowClientEmailReconnect Boolean   @default(true)
  maxOutlookConnections     Int       @default(1)
  maxGmailConnections       Int       @default(1)
  maxWhatsappConnections    Int       @default(0)

  users           User[]
  cin7            Cin7Connection?
  outlook         OutlookConnection[]
  gmail           GmailConnection[]
  products        Product[]
  customers       Customer[]
  aliases         ProductAlias[]
  customerAliases CustomerAlias[]
  orders          Order[]
  orderFeedback   OrderFeedback[]
  activityLogs    ActivityLog[]
  systemLogs      SystemLog[]
}

model User {
  id                    String        @id @default(cuid())
  email                 String        @unique
  passwordHash          String
  name                  String?
  role                  String        @default("CLIENT")
  sessionTimeoutMinutes Int           @default(720)
  lastLoginAt           DateTime?
  companyId             String
  company               Company       @relation(fields: [companyId], references: [id])
  createdAt             DateTime      @default(now())
  activityLogs          ActivityLog[]
}

model Cin7Connection {
  id              String   @id @default(cuid())
  companyId       String   @unique
  company         Company  @relation(fields: [companyId], references: [id])
  accountId       String
  apiKeyEncrypted String
  baseUrl         String   @default("https://inventory.dearsystems.com/ExternalApi/v2")
  updatedAt       DateTime @updatedAt
}

model OutlookConnection {
  id                    String    @id @default(cuid())
  companyId             String
  company               Company   @relation(fields: [companyId], references: [id])
  email                 String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  expiresAt             DateTime?
  isActive              Boolean   @default(true)
  lastCheckedAt         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([companyId])
  @@index([companyId, isActive])
}

model GmailConnection {
  id                    String   @id @default(cuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id])
  email                 String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  expiryDate            BigInt?
  isActive              Boolean  @default(true)
  lastCheckedAt         DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, isActive])
}

model Product {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  cin7Id    String?
  sku       String?
  name      String
  barcode   String?
  uom       String?
  status    String?
  updatedAt DateTime @updatedAt

  @@unique([companyId, cin7Id])
  @@index([companyId, sku])
  @@index([companyId, name])
}

model Customer {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  cin7Id    String?
  name      String
  email     String?
  phone     String?
  updatedAt DateTime @updatedAt

  @@unique([companyId, cin7Id])
  @@index([companyId, name])
  @@index([companyId, email])
}

model CustomerAlias {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  rawText    String
  customerId String
  confidence Float    @default(1)
  timesUsed  Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, rawText])
  @@index([companyId, customerId])
}

model ProductAlias {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  customerId String?
  rawText    String
  productId  String
  confidence Float    @default(1)
  timesUsed  Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, customerId, rawText])
  @@index([companyId, productId])
}

model Order {
  id                 String      @id @default(cuid())
  companyId          String
  company            Company     @relation(fields: [companyId], references: [id])
  source             String
  sourceConnectionId String?
  sourceAccount      String?
  sourceMessageId    String?
  sender             String?
  subject            String?
  originalText       String
  customerText       String?
  customerId         String?
  poNumber           String?
  status             OrderStatus @default(NEW)
  cin7SaleId         String?
  error              String?
  createdAt          DateTime    @default(now())

  lines              OrderLine[]

  @@index([companyId, customerId])
  @@index([companyId, status])
  @@index([companyId, source])
  @@index([companyId, sourceConnectionId])
  @@index([companyId, sourceMessageId])
}

model OrderLine {
  id             String     @id @default(cuid())
  orderId        String
  order          Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rawProductText String
  productId      String?
  productName    String?
  sku            String?
  quantity       Float
  uom            String?
  confidence     Float      @default(0)
  status         LineStatus @default(UNMATCHED)
}

model OrderFeedback {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  feedbackType    String
  comment         String?
  source          String?
  sourceAccount   String?
  sender          String?
  subject         String?
  originalText    String?
  sourceMessageId String?
  createdAt       DateTime @default(now())

  @@index([companyId, feedbackType])
  @@index([companyId, source])
  @@index([companyId, createdAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorEmail  String?
  action      String
  entityType  String?
  entityId    String?
  message     String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model SystemLog {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  level     String
  source    String?
  message   String
  details   Json?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([level, createdAt])
  @@index([source, createdAt])
}
